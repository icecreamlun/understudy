# Copy this file to `.env.local` and fill in your key.
# `.env.local` is git-ignored and loaded automatically at runtime.

# Required: OpenAI API key — Understudy's engine runs entirely through the
# OpenAI Codex CLI (`codex exec`) in API-key mode.
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: pin a model for the Codex CLI (otherwise the CLI's default is used).
# CODEX_MODEL=gpt-5.5

# Optional: HydraDB gives the skill-feedback loop long-term, cross-session memory.
# Without it, feedback memory falls back to a local mirror automatically.
# HYDRA_DB_API_KEY=sk_live_your-key-here
# HYDRA_TENANT_ID=default-tenant
# HYDRA_SUB_TENANT=controller
